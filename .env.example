# Environment Configuration
# Copy this file to .env.local for local development or .env for production

# Backend API Configuration
EXPO_PUBLIC_API_BASE_URL=https://api.beyondagri.com
EXPO_PUBLIC_API_VERSION=v1

# Development Features (set to "true" to enable)
EXPO_PUBLIC_ENABLE_HIDDEN_FEATURES=false

# Local Development Example (.env.local):
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
# EXPO_PUBLIC_API_VERSION=v1
# EXPO_PUBLIC_ENABLE_HIDDEN_FEATURES=true

# Notes:
# - Production API: https://api.beyondagri.com/api/v1/*
# - Local API: http://localhost:8000/api/v1/* (FastAPI backend)
# - Local API Docs: http://localhost:8000/docs
# - Hidden features: Development tools and debug features

