# Project Configuration
PROJECT_NAME=BeyondAgri
API_V1_STR=/api/v1
VERSION=0.1.0
ENVIRONMENT=development

# CORS Settings
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=beyondagri_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=beyondagri
DATABASE_URL=postgresql://beyondagri_user:your_password_here@localhost/beyondagri

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# AWS Cognito Configuration
COGNITO_USER_POOL_ID=your_cognito_user_pool_id
COGNITO_CLIENT_ID=your_cognito_client_id
COGNITO_REGION=us-east-1

# Email Configuration (Optional)
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password
EMAILS_FROM_EMAIL=noreply@beyondagri.com
EMAILS_FROM_NAME=BeyondAgri