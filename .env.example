# Environment Configuration
# Copy this file to .env and fill in your values

# Backend API Configuration
EXPO_PUBLIC_API_BASE_URL=https://api.beyondagri.com
EXPO_PUBLIC_API_VERSION=v1

# Optional: If you still want to use AWS Cognito alongside backend auth
# EXPO_PUBLIC_AWS_REGION=us-east-1
# EXPO_PUBLIC_USER_POOL_ID=your_user_pool_id_here
# EXPO_PUBLIC_USER_POOL_CLIENT_ID=your_user_pool_client_id_here